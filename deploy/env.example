# PolyPulse deployment env for /home/PolyPulse/.env
# Keep real secrets only on the server. Do not commit /home/PolyPulse/.env.

# ─── Execution Mode ───────────────────────────────────────────────────────────
# POLYPULSE_EXECUTION_MODE: Only "live" is supported. Reads current Polymarket real markets.
POLYPULSE_EXECUTION_MODE=live

# POLYPULSE_LIVE_WALLET_MODE: "simulated" uses in-memory paper-trading ledger (no real wallet);
# "real" connects to a real wallet and can submit real orders via Polymarket CLOB.
POLYPULSE_LIVE_WALLET_MODE=simulated

# ─── Live Real Wallet Credentials ─────────────────────────────────────────────
# Required only when POLYPULSE_LIVE_WALLET_MODE=real.

# PRIVATE_KEY: Polygon wallet private key for signing CLOB orders. Keep server-local only.
PRIVATE_KEY=

# FUNDER_ADDRESS: 0x-prefixed 20-byte hex address of the wallet funding CLOB collateral.
FUNDER_ADDRESS=

# SIGNATURE_TYPE: Polymarket CLOB signature type (e.g. EOA, POLY_GNOSIS_SAFE).
SIGNATURE_TYPE=

# CHAIN_ID: Must be 137 (Polygon mainnet) for Polymarket.
CHAIN_ID=137

# POLYMARKET_HOST: Polymarket CLOB API endpoint for order submission.
POLYMARKET_HOST=https://clob.polymarket.com

# ─── Simulated Live Wallet ─────────────────────────────────────────────────────
# Used when POLYPULSE_LIVE_WALLET_MODE=simulated. Still reads live Polymarket markets,
# but does not connect a real wallet or submit real orders. Paper-trading ledger is
# in-memory; only human-readable logs are persisted.

# SIMULATED_WALLET_ADDRESS: Optional 0x address for simulated wallet identity. Can be blank.
SIMULATED_WALLET_ADDRESS=

# SIMULATED_WALLET_BALANCE_USD: Initial cash for the in-memory paper-trading ledger (USD).
SIMULATED_WALLET_BALANCE_USD=100

# SIMULATED_MONITOR_LOG_PATH: Path to append human-readable simulated monitor logs.
SIMULATED_MONITOR_LOG_PATH=/home/PolyPulse/logs/polypulse-simulated-monitor.log

# ─── Market Data ───────────────────────────────────────────────────────────────
# POLYPULSE_MARKET_SOURCE: Market data source. Only "polymarket" is supported.
POLYPULSE_MARKET_SOURCE=polymarket

# POLYMARKET_GAMMA_HOST: Polymarket Gamma API for market metadata (topics, outcomes, etc.).
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com

# ─── Server-Local Persistence ──────────────────────────────────────────────────
# STATE_DIR: Directory for persistent state files (monitor stop/resume, calibration history).
STATE_DIR=/home/PolyPulse/runtime-artifacts/state

# ARTIFACT_DIR: Root directory for runtime artifacts (predictions, runs, monitor, etc.).
ARTIFACT_DIR=/home/PolyPulse/runtime-artifacts

# ─── Risk Controls ─────────────────────────────────────────────────────────────
# MAX_TRADE_PCT: Maximum single trade size as fraction of bankroll (0-1].
MAX_TRADE_PCT=0.05

# MAX_TOTAL_EXPOSURE_PCT: Maximum total exposure across all positions as fraction of bankroll (0-1].
MAX_TOTAL_EXPOSURE_PCT=0.5

# MAX_EVENT_EXPOSURE_PCT: Maximum exposure to a single event as fraction of bankroll (0-1].
MAX_EVENT_EXPOSURE_PCT=0.2

# MAX_POSITION_COUNT: Maximum number of concurrent open positions.
MAX_POSITION_COUNT=20

# MAX_POSITION_LOSS_PCT: Stop-loss threshold per position as fraction of entry cost (0-1].
MAX_POSITION_LOSS_PCT=0.5

# DRAWDOWN_HALT_PCT: Halt all trading when portfolio drawdown exceeds this fraction (0-1].
DRAWDOWN_HALT_PCT=0.2

# LIQUIDITY_TRADE_CAP_PCT: Max trade size as fraction of market liquidity (0-1], prevents market impact.
LIQUIDITY_TRADE_CAP_PCT=0.01

# MARKET_MAX_AGE_SECONDS: Maximum acceptable age of market data before considered stale.
MARKET_MAX_AGE_SECONDS=600

# MIN_AI_CONFIDENCE: Minimum AI confidence level to allow execution: low, medium, or high.
MIN_AI_CONFIDENCE=medium

# MIN_TRADE_USD: Minimum trade amount in USD. Trades below this are skipped.
MIN_TRADE_USD=1

# ─── Market Scan Settings ──────────────────────────────────────────────────────
# MARKET_SCAN_LIMIT: Total number of markets to scan per round from Gamma API.
MARKET_SCAN_LIMIT=5000

# MARKET_PAGE_SIZE: Number of markets per API page request (max 500).
MARKET_PAGE_SIZE=500

# MARKET_MAX_PAGES: Maximum pages to fetch from Gamma API per scan.
MARKET_MAX_PAGES=20

# MARKET_CACHE_TTL_SECONDS: Cache TTL for market data. 0 = no caching (always fresh).
MARKET_CACHE_TTL_SECONDS=0

# MARKET_REQUEST_TIMEOUT_MS: HTTP request timeout for Gamma API calls (ms).
MARKET_REQUEST_TIMEOUT_MS=10000

# MARKET_REQUEST_RETRIES: Number of retries for failed Gamma API requests.
MARKET_REQUEST_RETRIES=2

# MARKET_RATE_LIMIT_MS: Minimum delay between consecutive Gamma API requests (ms).
MARKET_RATE_LIMIT_MS=300

# MARKET_MIN_FETCHED: Minimum markets that must be fetched for scan to be considered valid.
MARKET_MIN_FETCHED=5000

# ─── Pulse Strategy Settings ──────────────────────────────────────────────────
# PULSE_STRATEGY: Strategy mode. Only "pulse-direct" is supported (Predict-Raven compatible).
PULSE_STRATEGY=pulse-direct

# PULSE_MIN_LIQUIDITY_USD: Minimum market liquidity (USD) to be eligible as candidate.
PULSE_MIN_LIQUIDITY_USD=5000

# PULSE_MAX_CANDIDATES: Maximum candidates to consider per round after rule pre-filter.
PULSE_MAX_CANDIDATES=20

# PULSE_REPORT_CANDIDATES: Number of top candidates to include in final report/execution.
PULSE_REPORT_CANDIDATES=4

# PULSE_BATCH_CAP_PCT: Maximum fraction of bankroll to deploy in a single round (0-1].
PULSE_BATCH_CAP_PCT=0.2

# PULSE_AI_CANDIDATE_TRIAGE: Enable AI semantic clustering and triage of candidates (true/false).
PULSE_AI_CANDIDATE_TRIAGE=true

# PULSE_AI_TRIAGE_CAN_REJECT: Allow AI triage to reject candidates (true/false).
PULSE_AI_TRIAGE_CAN_REJECT=true

# PULSE_AI_PRESCREEN: Enable lightweight AI pre-screen for information advantage (TRADE/SKIP).
# Runs before candidate triage; 60s timeout; failure preserves all candidates as TRADE.
PULSE_AI_PRESCREEN=true

# PULSE_PRESCREEN_TIMEOUT_MS: Timeout for AI pre-screen step (ms). Default 60000.
PULSE_PRESCREEN_TIMEOUT_MS=60000

# PULSE_AI_TOPIC_DISCOVERY: Enable AI-driven external topic discovery at start of each round.
# Provider discovers new topics from news/sports/macro/crypto signals, outputs search terms.
PULSE_AI_TOPIC_DISCOVERY=true

# PULSE_TOPIC_DISCOVERY_TIMEOUT_MS: Timeout for AI topic discovery step (ms). Default 60000.
PULSE_TOPIC_DISCOVERY_TIMEOUT_MS=60000

# PULSE_CALIBRATION_ENABLED: Enable probability calibration layer (shrinkage toward 0.5 prior).
# Applied after AI probability estimation, before decision engine.
PULSE_CALIBRATION_ENABLED=true

# PULSE_SEMANTIC_DISCOVERY: Enable semantic discovery runtime that matches discovered topics
# against full Polymarket market list using token-based similarity and clustering.
PULSE_SEMANTIC_DISCOVERY=true

# PULSE_SEMANTIC_DISCOVERY_MAX_MATCHED: Max markets to match via semantic discovery per round.
PULSE_SEMANTIC_DISCOVERY_MAX_MATCHED=10

# PULSE_SEMANTIC_DISCOVERY_SIMILARITY_THRESHOLD: Minimum token similarity for clustering (0-1).
PULSE_SEMANTIC_DISCOVERY_SIMILARITY_THRESHOLD=0.3

# PULSE_DYNAMIC_CALIBRATION: Enable dynamic calibration using historical prediction outcomes.
# Builds calibration curves from Brier score feedback. Requires sufficient history.
PULSE_DYNAMIC_CALIBRATION=true

# PULSE_DOWNSIDE_RISK_RANKING: Enable downside risk scoring and cross-round capital allocation
# in opportunity ranking. Considers max loss, liquidity risk, time risk, category concentration.
PULSE_DOWNSIDE_RISK_RANKING=true

# PULSE_PERFORMANCE_REPORT_INTERVAL: Emit prediction performance evaluation report every N rounds.
# Report includes hit rate, Brier score, calibration, edge accuracy by category/confidence.
PULSE_PERFORMANCE_REPORT_INTERVAL=5

# PULSE_FETCH_DIMENSIONS: Gamma API dimensions to fetch (comma-separated).
PULSE_FETCH_DIMENSIONS=volume24hr,liquidity,startDate,competitive

# PULSE_REQUIRE_EVIDENCE_GUARD: Hard-block trades when evidence is insufficient (true/false).
# false = warning only, consistent with Predict-Raven pulse-direct service layer separation.
PULSE_REQUIRE_EVIDENCE_GUARD=false

# ─── Evidence Collection Settings ──────────────────────────────────────────────
# EVIDENCE_CACHE_TTL_SECONDS: TTL for cached evidence items (seconds). 1800 = 30 minutes.
EVIDENCE_CACHE_TTL_SECONDS=1800

# EVIDENCE_REQUEST_TIMEOUT_MS: Default HTTP timeout for evidence adapter requests (ms).
EVIDENCE_REQUEST_TIMEOUT_MS=10000

# EVIDENCE_REQUEST_RETRIES: Retries for failed evidence adapter requests.
EVIDENCE_REQUEST_RETRIES=1

# --- Page Scrape (Polymarket event page __NEXT_DATA__) ---
# EVIDENCE_PAGE_SCRAPE: Scrape Polymarket event pages for resolution rules, annotations, comments.
# Aligns with Predict-Raven scrape-market.ts deep research step.
EVIDENCE_PAGE_SCRAPE=true

# EVIDENCE_PAGE_COMMENT_LIMIT: Max community comments to extract from page scrape.
EVIDENCE_PAGE_COMMENT_LIMIT=10

# EVIDENCE_PAGE_TIMEOUT_MS: Timeout for page scrape HTTP request (ms).
EVIDENCE_PAGE_TIMEOUT_MS=15000

# --- Order Book Depth (Polymarket CLOB) ---
# EVIDENCE_ORDERBOOK_DEPTH: Fetch order book depth from CLOB for market microstructure evidence.
# Provides best bid/ask, spread, 2% depth, top N levels. Aligns with Predict-Raven orderbook.ts.
EVIDENCE_ORDERBOOK_DEPTH=true

# EVIDENCE_ORDERBOOK_TIMEOUT_MS: Timeout for order book API request (ms).
EVIDENCE_ORDERBOOK_TIMEOUT_MS=10000

# EVIDENCE_ORDERBOOK_DEPTH_LEVELS: Number of order book levels to fetch per side.
EVIDENCE_ORDERBOOK_DEPTH_LEVELS=5

# --- Resolution Source Live Verification ---
# EVIDENCE_RESOLUTION_SOURCE_LIVE: Fetch and verify resolution source URL in real time.
# Prevents AI from using stale facts. Aligns with Predict-Raven SKILL.md A0 module.
EVIDENCE_RESOLUTION_SOURCE_LIVE=true

# EVIDENCE_RESOLUTION_SOURCE_TIMEOUT_MS: Timeout for resolution source HTTP fetch (ms).
EVIDENCE_RESOLUTION_SOURCE_TIMEOUT_MS=15000

# EVIDENCE_RESOLUTION_SOURCE_MAX_CONTENT: Max characters to extract from resolution source page.
EVIDENCE_RESOLUTION_SOURCE_MAX_CONTENT=8000

# --- Domain-Specific Research Adapters ---
# EVIDENCE_DOMAIN_ADAPTERS: Enable 5 domain-specific adapters (sports, macro, weather, on-chain, financial).
# Auto-activates by market category/question. Uses DuckDuckGo HTML search.
EVIDENCE_DOMAIN_ADAPTERS=true

# EVIDENCE_DOMAIN_ADAPTER_TIMEOUT_MS: Timeout for each domain adapter search request (ms).
EVIDENCE_DOMAIN_ADAPTER_TIMEOUT_MS=10000

# --- Evidence Gap Auto-Fill ---
# EVIDENCE_GAP_AUTO_FILL: Automatically fill evidence gaps identified by AI triage.
# Searches external public info by gap category (news, social, expert, official, etc.).
EVIDENCE_GAP_AUTO_FILL=true

# EVIDENCE_GAP_FETCH_TIMEOUT_MS: Timeout per individual gap search request (ms).
EVIDENCE_GAP_FETCH_TIMEOUT_MS=10000

# EVIDENCE_GAP_TOTAL_BUDGET_MS: Total time budget for all gap-filling per market (ms).
EVIDENCE_GAP_TOTAL_BUDGET_MS=30000

# EVIDENCE_GAP_MAX_PER_MARKET: Maximum evidence gaps to fill per market.
EVIDENCE_GAP_MAX_PER_MARKET=3

# MIN_EVIDENCE_ITEMS: Minimum evidence items required before probability estimation.
# Below this threshold, a warning is issued (or blocked if PULSE_REQUIRE_EVIDENCE_GUARD=true).
MIN_EVIDENCE_ITEMS=2

# ─── Monitor Settings ──────────────────────────────────────────────────────────
# MONITOR_INTERVAL_SECONDS: Seconds between monitor rounds when running --loop.
MONITOR_INTERVAL_SECONDS=300

# MONITOR_MAX_TRADES_PER_ROUND: Maximum trades (opens) allowed per monitor round.
MONITOR_MAX_TRADES_PER_ROUND=2

# MONITOR_MAX_DAILY_TRADE_USD: Maximum USD deployed across all trades per calendar day.
MONITOR_MAX_DAILY_TRADE_USD=20

# MONITOR_CONCURRENCY: Number of candidates to process concurrently per round.
MONITOR_CONCURRENCY=2

# MONITOR_RUN_TIMEOUT_MS: Maximum wall-clock time for a single monitor round (ms).
MONITOR_RUN_TIMEOUT_MS=120000

# MONITOR_BACKOFF_MS: Backoff delay after errors before retrying (ms).
MONITOR_BACKOFF_MS=1000

# MONITOR_WATCHLIST: Comma-separated market slugs. If set, only these markets are considered.
MONITOR_WATCHLIST=

# MONITOR_BLOCKLIST: Comma-separated market slugs to always exclude from consideration.
MONITOR_BLOCKLIST=

# ─── Artifact Retention ────────────────────────────────────────────────────────
# ARTIFACT_RETENTION_DAYS: Days to keep runtime artifacts before cleanup.
ARTIFACT_RETENTION_DAYS=14

# ARTIFACT_MAX_RUNS: Maximum run artifacts to keep (oldest pruned first).
ARTIFACT_MAX_RUNS=500

# ─── AI Provider ───────────────────────────────────────────────────────────────
# AI_PROVIDER: Primary AI provider for probability estimation. "codex" or "claude-code".
AI_PROVIDER=codex

# AI_MODEL: Override model for the AI provider. Empty = use provider default.
AI_MODEL=

# ─── Predict-Raven Compatible Codex Provider Settings ──────────────────────────
# AGENT_RUNTIME_PROVIDER: Which provider runtime to use for predictions. "codex" or "claude-code".
AGENT_RUNTIME_PROVIDER=codex

# PROVIDER_TIMEOUT_SECONDS: Timeout for provider subprocess. 0 = no separate timeout (uses monitor timeout).
PROVIDER_TIMEOUT_SECONDS=0

# CODEX_MODEL: Override model for Codex CLI. Empty = use Codex CLI default.
CODEX_MODEL=

# CODEX_SKILL_ROOT_DIR: Root directory for skill files read by Codex.
CODEX_SKILL_ROOT_DIR=skills

# CODEX_SKILL_LOCALE: Locale for skill templates and prompts: "zh" (Chinese) or "en" (English).
CODEX_SKILL_LOCALE=zh

# CODEX_SKILLS: Comma-separated skill IDs to load. Default: polypulse-market-agent.
CODEX_SKILLS=polypulse-market-agent

# ─── Claude Code Provider Settings ────────────────────────────────────────────
# Mirrors the Codex block above but routes ProbabilityEstimate through `claude --print`.

# CLAUDE_CODE_MODEL: Override model for Claude Code. Empty = use Claude Code default.
CLAUDE_CODE_MODEL=

# CLAUDE_CODE_SKILL_ROOT_DIR: Root directory for skill files read by Claude Code.
CLAUDE_CODE_SKILL_ROOT_DIR=skills

# CLAUDE_CODE_SKILL_LOCALE: Locale for skill templates and prompts: "zh" or "en".
CLAUDE_CODE_SKILL_LOCALE=zh

# CLAUDE_CODE_SKILLS: Comma-separated skill IDs to load.
CLAUDE_CODE_SKILLS=polypulse-market-agent

# CLAUDE_CODE_PERMISSION_MODE: Claude Code permission mode (e.g. bypassPermissions for non-interactive).
CLAUDE_CODE_PERMISSION_MODE=bypassPermissions

# CLAUDE_CODE_ALLOWED_TOOLS: Comma-separated tools allowed for Claude Code (e.g. Read,Glob,Grep).
CLAUDE_CODE_ALLOWED_TOOLS=Read,Glob,Grep

# CLAUDE_CODE_EXTRA_ARGS: Extra CLI arguments passed to claude command.
CLAUDE_CODE_EXTRA_ARGS=

# CLAUDE_CODE_MAX_BUDGET_USD: Maximum budget in USD for a single Claude Code invocation. Empty = no limit.
CLAUDE_CODE_MAX_BUDGET_USD=
