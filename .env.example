# PolyPulse safe defaults. Do not commit real secret values.

POLYPULSE_EXECUTION_MODE=paper
POLYPULSE_LIVE_WALLET_MODE=real

# Live broker credentials. Required only for explicit live execution.
PRIVATE_KEY=
FUNDER_ADDRESS=
SIGNATURE_TYPE=
CHAIN_ID=137
POLYMARKET_HOST=

# Simulated live wallet. Use only for live-path dry-run deployment; it never
# submits real Polymarket orders.
SIMULATED_WALLET_ADDRESS=
SIMULATED_WALLET_BALANCE_USD=100

# Public market data source. Use mock for offline tests.
POLYPULSE_MARKET_SOURCE=polymarket
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com

# Local persistence.
STATE_DIR=runtime-artifacts/state
ARTIFACT_DIR=runtime-artifacts

# Risk controls.
MAX_TRADE_PCT=0.05
MAX_TOTAL_EXPOSURE_PCT=0.5
MAX_EVENT_EXPOSURE_PCT=0.2
MAX_POSITION_COUNT=20
MAX_POSITION_LOSS_PCT=0.5
DRAWDOWN_HALT_PCT=0.2
LIQUIDITY_TRADE_CAP_PCT=0.01
MARKET_MAX_AGE_SECONDS=600
MIN_AI_CONFIDENCE=medium
MIN_TRADE_USD=1

# Scan and monitor defaults.
MARKET_SCAN_LIMIT=1000
MARKET_PAGE_SIZE=100
MARKET_MAX_PAGES=20
MARKET_CACHE_TTL_SECONDS=300
MARKET_REQUEST_TIMEOUT_MS=10000
MARKET_REQUEST_RETRIES=2
MARKET_RATE_LIMIT_MS=250
MARKET_MIN_FETCHED=20
EVIDENCE_CACHE_TTL_SECONDS=1800
EVIDENCE_REQUEST_TIMEOUT_MS=10000
EVIDENCE_REQUEST_RETRIES=1
MIN_EVIDENCE_ITEMS=2
MONITOR_INTERVAL_SECONDS=300
MONITOR_MAX_TRADES_PER_ROUND=3
MONITOR_MAX_DAILY_TRADE_USD=25
MONITOR_CONCURRENCY=3
MONITOR_RUN_TIMEOUT_MS=120000
MONITOR_BACKOFF_MS=1000
MONITOR_WATCHLIST=
MONITOR_BLOCKLIST=
ARTIFACT_RETENTION_DAYS=14
ARTIFACT_MAX_RUNS=500

# AI provider command hook. Empty means deterministic local scaffold.
AI_PROVIDER=local
AI_MODEL=
AI_COMMAND=

# Predict-Raven compatible Codex provider-runtime settings. If
# AGENT_RUNTIME_PROVIDER=codex or AI_PROVIDER=codex, PolyPulse runs Codex in
# read-only mode and only accepts ProbabilityEstimate JSON.
AGENT_RUNTIME_PROVIDER=none
PROVIDER_TIMEOUT_SECONDS=0
CODEX_COMMAND=
CODEX_MODEL=
CODEX_SKILL_ROOT_DIR=skills
CODEX_SKILL_LOCALE=zh
CODEX_SKILLS=polypulse-market-agent
