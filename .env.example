# PolyPulse 环境变量模板
# 部署时复制到 /home/PolyPulse/.env，填入真实密钥。不要提交 .env 到版本控制。

# ─── 执行模式 ────────────────────────────────────────────────────────────────
# POLYPULSE_EXECUTION_MODE: 仅支持 "live"，读取 Polymarket 真实市场数据。
POLYPULSE_EXECUTION_MODE=live

# POLYPULSE_LIVE_WALLET_MODE: "simulated" 使用内存模拟账本（不连接真实钱包）；
# "real" 连接真实钱包并通过 Polymarket CLOB 提交订单。
POLYPULSE_LIVE_WALLET_MODE=simulated

# ─── 真实钱包凭证 ─────────────────────────────────────────────────────────────
# 仅当 POLYPULSE_LIVE_WALLET_MODE=real 时需要。

# PRIVATE_KEY: Polygon 钱包私钥，用于签署 CLOB 订单。仅限服务器本地保存。
PRIVATE_KEY=

# FUNDER_ADDRESS: 0x 开头的 20 字节 hex 地址，提供 CLOB 保证金的钱包。
FUNDER_ADDRESS=

# SIGNATURE_TYPE: Polymarket CLOB 签名类型（如 EOA、POLY_GNOSIS_SAFE）。
SIGNATURE_TYPE=

# CHAIN_ID: 必须为 137（Polygon 主网）。
CHAIN_ID=137

# POLYMARKET_HOST: Polymarket CLOB API 端点，用于提交订单。
POLYMARKET_HOST=https://clob.polymarket.com

# ─── 模拟钱包 ─────────────────────────────────────────────────────────────────
# 当 POLYPULSE_LIVE_WALLET_MODE=simulated 时使用。仍然读取真实市场数据，
# 但不连接真实钱包、不提交真实订单。模拟账本仅存内存；只持久化人类可读日志。

# SIMULATED_WALLET_ADDRESS: 可选，模拟钱包的 0x 地址标识。可留空。
SIMULATED_WALLET_ADDRESS=

# SIMULATED_WALLET_BALANCE_USD: 内存模拟账本的初始资金（美元）。
SIMULATED_WALLET_BALANCE_USD=100

# SIMULATED_MONITOR_LOG_PATH: 人类可读模拟 monitor 日志的追加路径。
SIMULATED_MONITOR_LOG_PATH=/home/PolyPulse/logs/polypulse-simulated-monitor.log

# ─── 市场数据 ─────────────────────────────────────────────────────────────────
# POLYPULSE_MARKET_SOURCE: 市场数据来源。仅支持 "polymarket"。
POLYPULSE_MARKET_SOURCE=polymarket

# POLYMARKET_GAMMA_HOST: Polymarket Gamma API，获取市场元数据（话题、结果等）。
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com

# ─── 服务器本地持久化 ─────────────────────────────────────────────────────────
# STATE_DIR: 持久化状态文件目录（monitor 停/恢复、校准历史等）。
STATE_DIR=/home/PolyPulse/runtime-artifacts/state

# ARTIFACT_DIR: 运行时产物根目录（预测结果、运行记录、monitor 等）。
ARTIFACT_DIR=/home/PolyPulse/runtime-artifacts

# ─── 风控参数 ─────────────────────────────────────────────────────────────────
# MAX_TRADE_PCT: 单笔交易最大占总资金比例 (0-1]。
MAX_TRADE_PCT=0.05

# MAX_TOTAL_EXPOSURE_PCT: 所有持仓总敞口最大占总资金比例 (0-1]。
MAX_TOTAL_EXPOSURE_PCT=0.5

# MAX_EVENT_EXPOSURE_PCT: 单事件最大敞口占总资金比例 (0-1]。
MAX_EVENT_EXPOSURE_PCT=0.2

# MAX_POSITION_COUNT: 同时持有的最大仓位数。
MAX_POSITION_COUNT=20

# MAX_POSITION_LOSS_PCT: 单仓位止损阈值，占入场成本比例 (0-1]。
MAX_POSITION_LOSS_PCT=0.5

# DRAWDOWN_HALT_PCT: 组合回撤超过此比例时暂停所有交易 (0-1]。
DRAWDOWN_HALT_PCT=0.2

# LIQUIDITY_TRADE_CAP_PCT: 单笔交易最大占市场流动性比例 (0-1]，防止市场冲击。
LIQUIDITY_TRADE_CAP_PCT=0.01

# MARKET_MAX_AGE_SECONDS: 市场数据最大允许年龄（秒），超过视为过时。
MARKET_MAX_AGE_SECONDS=600

# MIN_AI_CONFIDENCE: AI 最低置信度要求：low、medium 或 high。
MIN_AI_CONFIDENCE=medium

# MIN_TRADE_USD: 最小交易金额（美元），低于此值的交易被跳过。
MIN_TRADE_USD=1

# ─── 市场扫描设置 ─────────────────────────────────────────────────────────────
# MARKET_SCAN_LIMIT: 每轮从 Gamma API 扫描的市场总数。
MARKET_SCAN_LIMIT=5000

# MARKET_PAGE_SIZE: 每页 API 请求的市场数量（最大 500）。
MARKET_PAGE_SIZE=500

# MARKET_MAX_PAGES: 每次扫描从 Gamma API 获取的最大页数。
MARKET_MAX_PAGES=20

# MARKET_CACHE_TTL_SECONDS: 市场数据缓存 TTL。0 = 不缓存（始终获取最新）。
MARKET_CACHE_TTL_SECONDS=0

# MARKET_REQUEST_TIMEOUT_MS: Gamma API 请求超时（毫秒）。
MARKET_REQUEST_TIMEOUT_MS=10000

# MARKET_REQUEST_RETRIES: Gamma API 请求失败重试次数。
MARKET_REQUEST_RETRIES=2

# MARKET_RATE_LIMIT_MS: 连续 Gamma API 请求之间的最小延迟（毫秒）。
MARKET_RATE_LIMIT_MS=300

# MARKET_MIN_FETCHED: 扫描有效所需的最低市场获取数量。
MARKET_MIN_FETCHED=5000

# ─── Pulse 策略设置 ───────────────────────────────────────────────────────────
# PULSE_STRATEGY: 策略模式。仅支持 "pulse-direct"（兼容 Predict-Raven）。
PULSE_STRATEGY=pulse-direct

# PULSE_MIN_LIQUIDITY_USD: 候选市场最低流动性（美元）。
PULSE_MIN_LIQUIDITY_USD=5000

# PULSE_MAX_CANDIDATES: 规则预筛后每轮最大候选数。
PULSE_MAX_CANDIDATES=20

# PULSE_REPORT_CANDIDATES: 最终报告/执行中包含的 top 候选数。
PULSE_REPORT_CANDIDATES=4

# PULSE_BATCH_CAP_PCT: 单轮最大部署占总资金比例 (0-1]。
PULSE_BATCH_CAP_PCT=0.2

# PULSE_AI_CANDIDATE_TRIAGE: 启用 AI 语义聚类和候选 triage（true/false）。
PULSE_AI_CANDIDATE_TRIAGE=true

# PULSE_AI_TRIAGE_CAN_REJECT: 允许 AI triage 拒绝候选（true/false）。
PULSE_AI_TRIAGE_CAN_REJECT=true

# PULSE_AI_PRESCREEN: 启用轻量 AI pre-screen 判断信息优势（TRADE/SKIP）。
# 在 candidate triage 之前运行；60 秒超时；失败时保留全部候选为 TRADE。
PULSE_AI_PRESCREEN=true

# PULSE_PRESCREEN_TIMEOUT_MS: AI pre-screen 步骤超时（毫秒）。默认 60000。
PULSE_PRESCREEN_TIMEOUT_MS=60000

# PULSE_AI_EVIDENCE_RESEARCH: 启用 AI 引导的证据研究（在适配器收集后）。
# AI 评估证据充分性、识别信息缺口、指导定向搜索。
# 对齐 Predict-Raven 的 AI 驱动研究流水线。失败时回退到传统 gap-fill。
PULSE_AI_EVIDENCE_RESEARCH=true

# PULSE_EVIDENCE_RESEARCH_TIMEOUT_MS: AI 证据研究步骤超时（毫秒）。默认 60000。
PULSE_EVIDENCE_RESEARCH_TIMEOUT_MS=60000

# PULSE_EVIDENCE_RESEARCH_MAX_SEARCHES: AI 每个市场最大定向搜索数。
PULSE_EVIDENCE_RESEARCH_MAX_SEARCHES=5

# PULSE_AI_TOPIC_DISCOVERY: 启用 AI 驱动的外部话题发现（每轮开始时）。
# Provider 从新闻/体育/宏观/加密信号中发现新话题，输出搜索词。
PULSE_AI_TOPIC_DISCOVERY=true

# PULSE_TOPIC_DISCOVERY_TIMEOUT_MS: AI 话题发现步骤超时（毫秒）。默认 60000。
PULSE_TOPIC_DISCOVERY_TIMEOUT_MS=60000

# PULSE_CALIBRATION_ENABLED: 启用概率校准层（向 0.5 先验收缩）。
# 在 AI 概率估算后、决策引擎前应用。
PULSE_CALIBRATION_ENABLED=true

# PULSE_SEMANTIC_DISCOVERY: 启用语义发现运行时，将发现的话题与 Polymarket 市场列表
# 通过 token 相似度和聚类进行匹配。
PULSE_SEMANTIC_DISCOVERY=true

# PULSE_SEMANTIC_DISCOVERY_MAX_MATCHED: 每轮语义发现最大匹配市场数。
PULSE_SEMANTIC_DISCOVERY_MAX_MATCHED=10

# PULSE_SEMANTIC_DISCOVERY_SIMILARITY_THRESHOLD: 聚类最小 token 相似度 (0-1)。
PULSE_SEMANTIC_DISCOVERY_SIMILARITY_THRESHOLD=0.3

# PULSE_DYNAMIC_CALIBRATION: 启用动态校准（基于历史预测结果）。
# 利用 Brier 分数反馈构建校准曲线。需要足够的历史数据。
PULSE_DYNAMIC_CALIBRATION=true

# PULSE_DOWNSIDE_RISK_RANKING: 启用下行风险评分和跨轮资金分配。
# 考虑最大损失、流动性风险、时间风险、类别集中度。
PULSE_DOWNSIDE_RISK_RANKING=true

# PULSE_PERFORMANCE_REPORT_INTERVAL: 每 N 轮输出预测绩效评估报告。
# 报告含命中率、Brier 分数、校准、按类别/置信度的 edge 准确度。
PULSE_PERFORMANCE_REPORT_INTERVAL=5

# PULSE_FETCH_DIMENSIONS: 从 Gamma API 获取的维度（逗号分隔）。
PULSE_FETCH_DIMENSIONS=volume24hr,liquidity,startDate,competitive

# PULSE_REQUIRE_EVIDENCE_GUARD: 证据不足时硬阻止交易（true/false）。
# false = 仅警告，与 Predict-Raven pulse-direct 服务层分离一致。
PULSE_REQUIRE_EVIDENCE_GUARD=false

# ─── 证据收集设置 ─────────────────────────────────────────────────────────────
# EVIDENCE_CACHE_TTL_SECONDS: 证据缓存 TTL（秒）。1800 = 30 分钟。
EVIDENCE_CACHE_TTL_SECONDS=1800

# EVIDENCE_REQUEST_TIMEOUT_MS: 证据适配器默认 HTTP 超时（毫秒）。
EVIDENCE_REQUEST_TIMEOUT_MS=10000

# EVIDENCE_REQUEST_RETRIES: 证据适配器请求失败重试次数。
EVIDENCE_REQUEST_RETRIES=1

# --- 页面抓取（Polymarket 事件页 __NEXT_DATA__）---
# EVIDENCE_PAGE_SCRAPE: 抓取 Polymarket 事件页获取结算规则、注解、评论。
# 对齐 Predict-Raven scrape-market.ts 深度研究步骤。
EVIDENCE_PAGE_SCRAPE=true

# EVIDENCE_PAGE_COMMENT_LIMIT: 页面抓取提取的最大社区评论数。
EVIDENCE_PAGE_COMMENT_LIMIT=10

# EVIDENCE_PAGE_TIMEOUT_MS: 页面抓取 HTTP 请求超时（毫秒）。
EVIDENCE_PAGE_TIMEOUT_MS=15000

# --- 订单簿深度（Polymarket CLOB）---
# EVIDENCE_ORDERBOOK_DEPTH: 从 CLOB 获取订单簿深度作为市场微观结构证据。
# 提供最优买/卖价、价差、2% 深度、前 N 档。对齐 Predict-Raven orderbook.ts。
EVIDENCE_ORDERBOOK_DEPTH=true

# EVIDENCE_ORDERBOOK_TIMEOUT_MS: 订单簿 API 请求超时（毫秒）。
EVIDENCE_ORDERBOOK_TIMEOUT_MS=10000

# EVIDENCE_ORDERBOOK_DEPTH_LEVELS: 每侧获取的订单簿档位数。
EVIDENCE_ORDERBOOK_DEPTH_LEVELS=5

# --- 结算来源实时验证 ---
# EVIDENCE_RESOLUTION_SOURCE_LIVE: 实时获取并验证结算来源 URL。
# 防止 AI 使用过时事实。对齐 Predict-Raven SKILL.md A0 模块。
EVIDENCE_RESOLUTION_SOURCE_LIVE=true

# EVIDENCE_RESOLUTION_SOURCE_TIMEOUT_MS: 结算来源 HTTP 获取超时（毫秒）。
EVIDENCE_RESOLUTION_SOURCE_TIMEOUT_MS=15000

# EVIDENCE_RESOLUTION_SOURCE_MAX_CONTENT: 从结算来源页面提取的最大字符数。
EVIDENCE_RESOLUTION_SOURCE_MAX_CONTENT=8000

# --- 领域专用研究适配器 ---
# EVIDENCE_DOMAIN_ADAPTERS: 启用 5 个领域适配器（体育、宏观、天气、链上、金融）。
# 按市场类别/问题自动激活。使用 DuckDuckGo HTML 搜索。
EVIDENCE_DOMAIN_ADAPTERS=true

# EVIDENCE_DOMAIN_ADAPTER_TIMEOUT_MS: 每个领域适配器搜索请求超时（毫秒）。
EVIDENCE_DOMAIN_ADAPTER_TIMEOUT_MS=10000

# --- 证据缺口自动补全 ---
# EVIDENCE_GAP_AUTO_FILL: 自动补全 AI triage 识别的证据缺口。
# 按缺口类别（新闻、社交、专家、官方等）搜索外部公开信息。
EVIDENCE_GAP_AUTO_FILL=true

# EVIDENCE_GAP_FETCH_TIMEOUT_MS: 单个缺口搜索请求超时（毫秒）。
EVIDENCE_GAP_FETCH_TIMEOUT_MS=10000

# EVIDENCE_GAP_TOTAL_BUDGET_MS: 每个市场所有缺口补全的总时间预算（毫秒）。
EVIDENCE_GAP_TOTAL_BUDGET_MS=30000

# EVIDENCE_GAP_MAX_PER_MARKET: 每个市场最大补全证据缺口数。
EVIDENCE_GAP_MAX_PER_MARKET=3

# MIN_EVIDENCE_ITEMS: 概率估算前所需的最少证据条目。
# 低于此阈值会发出警告（如 PULSE_REQUIRE_EVIDENCE_GUARD=true 则阻止）。
MIN_EVIDENCE_ITEMS=2

# ─── Monitor 设置 ─────────────────────────────────────────────────────────────
# MONITOR_INTERVAL_SECONDS: 运行 --loop 时各轮之间的间隔（秒）。
MONITOR_INTERVAL_SECONDS=300

# MONITOR_MAX_TRADES_PER_ROUND: 每轮允许的最大交易（开仓）数。
MONITOR_MAX_TRADES_PER_ROUND=2

# MONITOR_MAX_DAILY_TRADE_USD: 每日所有交易的最大部署金额（美元）。
MONITOR_MAX_DAILY_TRADE_USD=20

# MONITOR_CONCURRENCY: 每轮并发处理的候选数。
MONITOR_CONCURRENCY=2

# MONITOR_RUN_TIMEOUT_MS: 单轮 monitor 最大运行时间（毫秒）。
MONITOR_RUN_TIMEOUT_MS=120000

# MONITOR_BACKOFF_MS: 出错后重试前的退避延迟（毫秒）。
MONITOR_BACKOFF_MS=1000

# MONITOR_WATCHLIST: 逗号分隔的市场 slug。设置后只关注这些市场。
MONITOR_WATCHLIST=

# MONITOR_BLOCKLIST: 逗号分隔的市场 slug，始终排除。
MONITOR_BLOCKLIST=

# ─── 产物保留 ─────────────────────────────────────────────────────────────────
# ARTIFACT_RETENTION_DAYS: 运行时产物保留天数，超过后清理。
ARTIFACT_RETENTION_DAYS=14

# ARTIFACT_MAX_RUNS: 最大保留运行产物数（超出从最旧开始清除）。
ARTIFACT_MAX_RUNS=500

# ─── AI Provider ──────────────────────────────────────────────────────────────
# AI_PROVIDER: 概率估算的主 AI 提供方。"codex" 或 "claude-code"。
AI_PROVIDER=codex

# AI_MODEL: 覆盖 AI 提供方模型。留空 = 使用提供方默认模型。
AI_MODEL=

# ─── Predict-Raven 兼容 Codex Provider 设置 ───────────────────────────────────
# AGENT_RUNTIME_PROVIDER: 预测使用的 provider 运行时。"codex" 或 "claude-code"。
AGENT_RUNTIME_PROVIDER=codex

# PROVIDER_TIMEOUT_SECONDS: Provider 子进程超时。0 = 无独立超时（使用 monitor 超时）。
PROVIDER_TIMEOUT_SECONDS=0

# CODEX_MODEL: 覆盖 Codex CLI 模型。留空 = 使用 Codex CLI 默认。
CODEX_MODEL=

# CODEX_SKILL_ROOT_DIR: Codex 读取的 skill 文件根目录。
CODEX_SKILL_ROOT_DIR=skills

# CODEX_SKILL_LOCALE: Skill 模板和提示词的语言："zh"（中文）或 "en"（英文）。
CODEX_SKILL_LOCALE=zh

# CODEX_SKILLS: 逗号分隔的 skill ID。默认：polypulse-market-agent。
CODEX_SKILLS=polypulse-market-agent

# ─── Claude Code Provider 设置 ────────────────────────────────────────────────
# 与上面 Codex 块对称，但通过 `claude --print` 路由 ProbabilityEstimate。

# CLAUDE_CODE_MODEL: 覆盖 Claude Code 模型。留空 = 使用 Claude Code 默认。
CLAUDE_CODE_MODEL=

# CLAUDE_CODE_SKILL_ROOT_DIR: Claude Code 读取的 skill 文件根目录。
CLAUDE_CODE_SKILL_ROOT_DIR=skills

# CLAUDE_CODE_SKILL_LOCALE: Skill 模板和提示词的语言："zh" 或 "en"。
CLAUDE_CODE_SKILL_LOCALE=zh

# CLAUDE_CODE_SKILLS: 逗号分隔的 skill ID。
CLAUDE_CODE_SKILLS=polypulse-market-agent

# CLAUDE_CODE_PERMISSION_MODE: Claude Code 权限模式（如 bypassPermissions 用于非交互式）。
CLAUDE_CODE_PERMISSION_MODE=bypassPermissions

# CLAUDE_CODE_ALLOWED_TOOLS: Claude Code 允许的工具（逗号分隔，如 Read,Glob,Grep）。
CLAUDE_CODE_ALLOWED_TOOLS=Read,Glob,Grep

# CLAUDE_CODE_EXTRA_ARGS: 传给 claude 命令的额外 CLI 参数。
CLAUDE_CODE_EXTRA_ARGS=

# CLAUDE_CODE_MAX_BUDGET_USD: 单次 Claude Code 调用的最大预算（美元）。留空 = 无限制。
CLAUDE_CODE_MAX_BUDGET_USD=
